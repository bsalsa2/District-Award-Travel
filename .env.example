# District Award Travel — environment variables
# Copy to .env for local reference (the app reads the real environment, not
# this file). On Render these live in the dashboard (Environment tab).
# Never commit real values.

# ── Core ─────────────────────────────────────────────────────────────────
# development | staging | production. With DATABASE_URL set the default is
# production (strict mode). Local dev with no DATABASE_URL: development.
ENV=development

# Postgres URL (Render injects this). Unset locally → SQLite ./dat.db
DATABASE_URL=

# REQUIRED in production — app refuses to boot without them.
SECRET_KEY=             # openssl rand -hex 32
ADMIN_PASSWORD=         # your admin login password
ADMIN_EMAIL=admin@districtawardtravel.com

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────
GMAIL_USER=districtawardtravel@gmail.com
GMAIL_APP_PASSWORD=     # 16-char Google App Password (not your real password)
NOTIFY_EMAIL=districtawardtravel@gmail.com
EMAIL_PROVIDER=gmail    # transport seam; only 'gmail' implemented today

# ── Integrations (all optional — graceful degradation when unset) ────────
GROQ_API_KEY=
GEMINI_API_KEY=
SEATS_AERO_API_KEY=

# ── Operations ───────────────────────────────────────────────────────────
CRON_SECRET=            # protects POST /api/cron/digest; openssl rand -hex 24
ALLOWED_ORIGINS=        # comma-separated extra CORS origins (defaults cover prod)
SLOW_QUERY_MS=200       # log queries slower than this

# Public proof-strip display floors (cents / counts)
PROOF_MIN_SAVINGS_CENTS=500000
PROOF_MIN_TRIPS=5
PROOF_MIN_CPP_RECORDS=3

# ── GitHub repo secrets (NOT app env — for .github/workflows) ────────────
# PROD_DATABASE_URL     Render External Database URL (for nightly backups)
# BACKUP_PASSPHRASE     openssl rand -base64 32; keep an offline copy!
